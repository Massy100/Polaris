{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/manage.py",
      "use": "@vercel/python",
      "config": {
        "installCommand": "pip install -r backend/requirements.txt"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/manage.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}